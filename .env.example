# ============================================================
#  Boutique high-tech — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs.
#  NE JAMAIS commiter .env.local
# ============================================================

# --- Base ---
MONGODB_URI=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email / Images / IA ---
RESEND_API_KEY=
RESEND_FROM="Boutique <commandes@tondomaine.fr>"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GEMINI_API_KEY=
# Modèle Gemini (défaut stable) et modèle de secours (bascule auto si quota 429/403)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash-8b

# --- Import AliExpress (API officielle dropshipping) ---
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# --- Crons (Authorization: Bearer ${CRON_SECRET}) ---
CRON_SECRET=

# --- Seed admin (utilisé par npm run seed:admin) ---
SEED_ADMIN_EMAIL=admin@boutique.fr
SEED_ADMIN_PASSWORD=changeme-please
SEED_ADMIN_NAME=Administrateur

# --- WhatsApp (PHASE 2 — laisser vide pour l'instant) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Portail d'accès admin (HTTP Basic Auth devant /admin, login compris)
# Laisser vide = portail désactivé. Définir les DEUX pour l'activer.
ADMIN_GATE_USER=
ADMIN_GATE_PASSWORD=
